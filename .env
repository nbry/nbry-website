# Environment Configuration
# Copied from .env.example

# Environment mode
SITE_MODE=development  # or production

# Database
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/nbry_website

# Redis
REDIS_URL=redis://redis:6379/0

# Domain settings (development with localhost)
ROOT_DOMAIN=nbry.com
LOCAL_DOMAIN=localhost
ALLOWED_SUBDOMAINS=["lifting","coffee","mycareer"]

# Site feature toggles
LIFTING_SITE_ENABLED=true
COFFEE_SITE_ENABLED=false
MYCAREER_SITE_ENABLED=true
