# Environment Configuration Example
# Copy this file to .env and update values as needed

# Environment mode
SITE_MODE=development  # or production

# Database
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/nbry_website

# Redis
REDIS_URL=redis://redis:6379/0

# Domain settings (production)
ROOT_DOMAIN=nbry.com
LOCAL_DOMAIN=nbry.local
ALLOWED_SUBDOMAINS=lifting,coffee,career

# Site feature toggles
LIFTING_SITE_ENABLED=true
COFFEE_SITE_ENABLED=false
CAREER_SITE_ENABLED=false
